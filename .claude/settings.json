{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "1800000",
    "BASH_MAX_TIMEOUT_MS": "7200000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90",
    "MCP_CONNECTION_NONBLOCKING": "true"
  },
  "sandbox": {
    "permissions": {
      "allowedDomains": [
        "github.com",
        "registry.npmjs.org",
        "objects.githubusercontent.com",
        "ghcr.io",
        "formulae.brew.sh",
        "raw.githubusercontent.com"
      ],
      "filesystem": {
        "allowWrite": [
          "/opt/homebrew",
          "/usr/local",
          "/tmp",
          "/Users/daijiromatsuokam1/Machinelab Dropbox"
        ]
      }
    }
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(python3 ~/scripts/search-chatlogs.py *)",
      "Bash(bash ~/scripts/proj.sh *)",
      "Bash(bash ~/scripts/project-search.sh *)",
      "Bash(prlctl list)",
      "Bash(prlctl list *)",
      "Bash(python3 ~/scripts/search-cc-sessions.py *)",
      "Bash(launchctl list *)",
      "Bash(launchctl list)",
      "Bash(launchctl print *)",
      "Bash(bash exec.sh *)",
      "Bash(curl https://jarvis-memory-gateway.jarvis-matsuoka.workers.dev/*)",
      "Bash(curl -s https://jarvis-memory-gateway.jarvis-matsuoka.workers.dev/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q \"\\.ts$\"; then cd ~/claude-telegram-bot && timeout 60 bun test --timeout 30000 2>&1 | tail -3; fi"
          }
        ]
      }
    ]
  }
}
